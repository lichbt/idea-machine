# Copy to .env and fill in. Never commit .env.

# LLM backend selection: LLM_BACKEND = auto (default) | cli | openai
#   auto   -> use the OpenAI-compatible endpoint below if configured, else the
#             Claude CLI; whichever isn't primary acts as the fallback.
#   cli    -> Claude CLI only (uses its own login/auth — run `claude login` once).
#   openai -> OpenAI-compatible endpoint only.
# LLM_BACKEND=auto

# OpenAI-compatible endpoint (local gateway / proxy / router, or OpenRouter).
# When LLM_API_KEY + LLM_BASE_URL are set they take precedence over OPENROUTER_*.
# Streaming (text/event-stream) responses are handled automatically.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# OpenRouter (used as the OpenAI-compatible endpoint when LLM_* above is unset):
OPENROUTER_API_KEY=
# Optional overrides:
# CLAUDE_CLI_BIN=claude
# CLAUDE_CLI_MODEL=sonnet
# CLAUDE_CLI_TIMEOUT=180
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

SERPER_API_KEY=

# Reddit OAuth (create a "script" app: https://www.reddit.com/prefs/apps)
#   CLIENT_ID  = the short string shown UNDER the app name (not the name)
#   CLIENT_SECRET = the field labelled "secret"
#   USER_AGENT must be descriptive, e.g. script:idea-machine:0.1 (by /u/you)
# A script app needs your Reddit USERNAME + PASSWORD too (password grant);
# leave those blank to use read-only application-only OAuth instead.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=script:idea-machine:0.1 (by /u/your_username)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Product Hunt API (developer token: https://www.producthunt.com/v2/oauth/applications)
PRODUCTHUNT_API_TOKEN=

# Telegram (bot token from @BotFather, chat id from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: override default sqlite path, e.g. postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///idea_machine.db
